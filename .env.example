# Connexion PostgreSQL (cf. packages/database/src/Sql.ts)
DB_HOST=localhost
DB_USER=postgres
DB_PWD=postgres
DB_NAME=crypto
DB_PORT=5432

# Pool de connexions (optionnel, valeurs par défaut indiquées)
DB_POOL_SIZE=10
DB_POOL_ACQUIRE_TIMEOUT_MS=10000

# Environnement (active le SSL en "production")
ENV=development
